{#
  ============================================================
  予約フォームモーダル パーシャル(フォーム送信体制用)
  ------------------------------------------------------------
  store.reserve_system == "form" のときだけインクルードされる。
  外部TableCheckではなく、ページ内モーダルで予約リクエストを受け、
  EmailJS で店舗とゲストにメールを送信する。

  店舗ごとに変わる値は store / store.form_config から差し込む。
   - EmailJS service_id / template_id / public_key
     → stores.brand には置かず、各 store.form_config に持つ(店舗で違える余地を残す)
   - 予約不可日(工事休業日など) → store.form_config.blocked_dates
   - メール本文に入る location / address / 電話番号 → store の各フィールド
  ============================================================
#}

<style>
  /* ===== Confirmation checkbox ===== */
  .confirm-checkbox {
    appearance: none; -webkit-appearance: none;
    width: 18px; height: 18px;
    border: 1.5px solid rgba(201,169,110,0.5); border-radius: 4px;
    background: #1a1a1a; cursor: pointer; position: relative;
    flex-shrink: 0; margin-top: 2px;
  }
  .confirm-checkbox:checked { background: #c9a96e; border-color: #c9a96e; }
  .confirm-checkbox:checked::after {
    content: ''; position: absolute; left: 5px; top: 1px;
    width: 5px; height: 10px;
    border: solid #090909; border-width: 0 2px 2px 0;
    transform: rotate(45deg);
  }

  /* ===== Course-card radio selector ===== */
  .form-course-card {
    display: block; position: relative;
    background: rgba(201,169,110,0.04);
    border: 1px solid rgba(201,169,110,0.25);
    border-radius: 12px; padding: 14px 16px;
    margin-bottom: 10px; cursor: pointer;
    transition: all 0.25s ease;
  }
  .form-course-card:hover {
    border-color: rgba(201,169,110,0.5);
    background: rgba(201,169,110,0.07);
  }
  .form-course-card input[type="radio"] {
    position: absolute; opacity: 0; pointer-events: none;
  }
  .form-course-card.popular {
    border-color: rgba(201,169,110,0.55);
    box-shadow: 0 0 16px rgba(201,169,110,0.12);
  }
  .form-course-card.popular::before {
    content: 'MOST POPULAR';
    position: absolute; top: 0; right: 12px;
    transform: translateY(-50%);
    background: #c9a96e; color: #090909;
    font-family: 'Josefin Sans', sans-serif;
    font-size: 8px; font-weight: 700; letter-spacing: 0.15em;
    padding: 3px 8px; border-radius: 999px; z-index: 2;
  }
  .form-course-card .check-mark {
    position: absolute; top: 12px; right: 12px;
    width: 18px; height: 18px;
    border: 1.5px solid rgba(201,169,110,0.4);
    border-radius: 50%; background: #1a1a1a;
    transition: all 0.2s ease;
  }
  .form-course-card input[type="radio"]:checked ~ .check-mark {
    border-color: #c9a96e; background: #c9a96e;
  }
  .form-course-card input[type="radio"]:checked ~ .check-mark::after {
    content: ''; position: absolute;
    left: 4px; top: 1px; width: 5px; height: 9px;
    border: solid #090909; border-width: 0 2px 2px 0;
    transform: rotate(45deg);
  }
  .form-course-card.selected {
    border-color: #c9a96e;
    background: rgba(201,169,110,0.10);
    box-shadow: 0 0 20px rgba(201,169,110,0.15);
  }
  .form-course-card-tier { font-family:'Josefin Sans',sans-serif; font-size:9px; letter-spacing:0.2em; color:rgba(201,169,110,0.65); text-transform:uppercase; margin-bottom:4px; }
  .form-course-card-name { font-family:'Cormorant Garamond',serif; font-style:italic; font-size:18px; color:#f0ede4; margin-bottom:6px; line-height:1.1; }
  .form-course-card-price { display:flex; align-items:baseline; gap:6px; margin-bottom:4px; }
  .form-course-card-price-main { font-family:'Josefin Sans',sans-serif; font-weight:700; font-size:16px; color:#c9a96e; }
  .form-course-card-price-tax { font-size:9px; color:rgba(240,237,228,0.4); }
  .form-course-card-meta { font-family:'Josefin Sans',sans-serif; font-size:10px; color:rgba(240,237,228,0.55); letter-spacing:0.03em; }
  .form-course-card-details { margin-top:10px; padding-top:10px; border-top:1px solid rgba(201,169,110,0.12); font-size:10px; color:rgba(240,237,228,0.55); line-height:1.65; }
  .form-course-card-details-row { display:flex; gap:8px; margin-bottom:3px; }
  .form-course-card-details-label { color:rgba(201,169,110,0.55); flex-shrink:0; width:42px; font-size:10px; }
  /* course picker cards */
  .cp-card{position:relative;border-radius:14px;overflow:hidden;margin-bottom:12px;background:rgba(201,169,110,0.04);border:1px solid rgba(201,169,110,0.2);}
  .cp-card.cp-pop{border-color:var(--cpcol);}
  .cp-bar{height:4px;background:var(--cpcol);}
  .cp-body{padding:14px 16px 16px;}
  .cp-pop-tag{position:absolute;top:10px;right:10px;background:#c9a96e;color:#090909;font-size:8px;font-weight:700;letter-spacing:0.12em;padding:3px 8px;border-radius:999px;font-family:'Josefin Sans',sans-serif;}
  .cp-badge{display:inline-flex;align-items:center;gap:5px;background:rgba(201,169,110,0.12);color:var(--cpcol);border:1px solid var(--cpcol);border-radius:999px;padding:2px 9px;font-size:9px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;font-family:'Josefin Sans',sans-serif;margin-bottom:8px;}
  .cp-name{font-family:'Cormorant Garamond',serif;font-size:19px;color:#f0ede4;margin-bottom:6px;line-height:1.15;}
  .cp-price{display:flex;align-items:baseline;gap:6px;margin-bottom:3px;}
  .cp-price-main{font-family:'Josefin Sans',sans-serif;font-weight:700;font-size:16px;color:#c9a96e;}
  .cp-price-tax{font-size:9px;color:rgba(240,237,228,0.4);}
  .cp-meta{font-family:'Josefin Sans',sans-serif;font-size:10px;color:rgba(240,237,228,0.5);margin-bottom:12px;}
  .cp-detbtn{width:100%;background:none;border:1px solid rgba(201,169,110,0.3);color:rgba(201,169,110,0.8);font-family:'Josefin Sans',sans-serif;font-size:10px;letter-spacing:0.1em;padding:8px;border-radius:8px;cursor:pointer;}
  .cp-detail{max-height:0;overflow:hidden;transition:max-height 0.35s ease;}
  .cp-detail-inner{border-top:1px solid rgba(201,169,110,0.12);padding-top:10px;margin-top:10px;}
  .cp-row{display:flex;gap:8px;margin-bottom:4px;font-size:10px;}
  .cp-row-label{color:rgba(201,169,110,0.5);flex-shrink:0;width:54px;}
  .cp-row-txt{color:rgba(240,237,228,0.6);}
  .cp-row-hl{color:var(--cpcol);font-weight:500;}
  .cp-sig{font-size:7px;letter-spacing:0.1em;text-transform:uppercase;color:var(--cpcol);border:1px solid var(--cpcol);border-radius:999px;padding:1px 5px;margin-left:3px;}
  .cp-select{width:100%;background:var(--cpcol);color:#0a0a0a;font-family:'Josefin Sans',sans-serif;font-weight:700;font-size:11px;letter-spacing:0.12em;text-transform:uppercase;padding:11px;border:none;border-radius:8px;cursor:pointer;margin-top:12px;}

  /* ===== Success screen animation ===== */
  .success-stage { position:relative; padding:40px 0 32px; text-align:center; overflow:hidden; }
  .gold-foil-bg {
    position:absolute; inset:0; pointer-events:none; opacity:0.6;
    background:
      radial-gradient(circle at 20% 30%, rgba(201,169,110,0.25) 0%, transparent 40%),
      radial-gradient(circle at 80% 60%, rgba(201,169,110,0.18) 0%, transparent 45%),
      radial-gradient(circle at 50% 85%, rgba(201,169,110,0.12) 0%, transparent 50%);
    animation: foilShimmer 4s ease-in-out infinite;
  }
  @keyframes foilShimmer {
    0%,100% { opacity:0.4; transform:scale(1); }
    50%     { opacity:0.7; transform:scale(1.05); }
  }
  .gold-particle {
    position:absolute; width:4px; height:4px;
    background:#c9a96e; border-radius:50%;
    opacity:0; animation: particleFloat 3s ease-out infinite;
    box-shadow:0 0 6px rgba(201,169,110,0.9), 0 0 12px rgba(201,169,110,0.5);
  }
  @keyframes particleFloat {
    0%   { opacity:0; transform:translate(0,0) scale(0); }
    20%  { opacity:1; transform:translate(var(--dx, 20px), -10px) scale(1); }
    80%  { opacity:0.6; transform:translate(calc(var(--dx, 20px) * 2), -40px) scale(0.7); }
    100% { opacity:0; transform:translate(calc(var(--dx, 20px) * 3), -80px) scale(0); }
  }
  .sumi-brush-svg { position:relative; z-index:2; width:110px; height:110px; margin:0 auto 20px; }
  .sumi-brush-svg path {
    fill:none; stroke:#c9a96e; stroke-width:5;
    stroke-linecap:round; stroke-linejoin:round;
    stroke-dasharray:600; stroke-dashoffset:600;
    filter:drop-shadow(0 0 8px rgba(201,169,110,0.7));
  }
  .sumi-brush-svg.drawing path { animation: drawSumi 1.6s cubic-bezier(0.65,0,0.35,1) forwards; }
  @keyframes drawSumi { 0% { stroke-dashoffset:600; } 100% { stroke-dashoffset:0; } }
  .success-title { position:relative; z-index:2; opacity:0; animation: fadeRise 0.8s ease-out 1.2s forwards; }
  .success-body  { position:relative; z-index:2; opacity:0; animation: fadeRise 0.8s ease-out 1.6s forwards; }
  .success-close { position:relative; z-index:2; opacity:0; animation: fadeRise 0.8s ease-out 2.0s forwards; }
  @keyframes fadeRise { 0% { opacity:0; transform:translateY(10px); } 100% { opacity:1; transform:translateY(0); } }
</style>

<!-- ============================================================
     RESERVATION MODAL(form-based)
     ============================================================ -->
<div id="reserveModal" style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,0.85);overflow-y:auto;-webkit-overflow-scrolling:touch;">
  <div style="min-height:100%;display:flex;align-items:center;justify-content:center;padding:20px;box-sizing:border-box;">
    <div style="background:#111;border:1px solid rgba(201,169,110,0.3);border-radius:16px;width:100%;max-width:480px;padding:32px 24px;position:relative;box-sizing:border-box;">
      <button onclick="closeReserveModal()" style="position:absolute;top:16px;right:16px;background:none;border:none;color:rgba(240,237,228,0.5);font-size:24px;cursor:pointer;line-height:1;">&#x00D7;</button>
      <p style="font-size:10px;letter-spacing:0.3em;color:rgba(201,169,110,0.6);text-transform:uppercase;margin:0 0 8px;">Reservation</p>
      <h3 style="font-family:'Cormorant Garamond',serif;font-style:italic;font-size:28px;color:#f0ede4;margin:0 0 4px;line-height:1.2;">Reservation Request</h3>
      <p style="font-size:12px;color:rgba(201,169,110,0.7);margin:0 0 4px;letter-spacing:0.05em;">予約リクエスト</p>
      <p style="font-size:12px;color:rgba(240,237,228,0.5);margin:0 0 24px;">We will send you a confirmation email.<br/>送信後、確認メールをお送りします。</p>

      <div id="reserveForm">
        {# Honeypot field — bots fill this, humans don't see it #}
        <div style="position:absolute;left:-9999px;top:-9999px;width:1px;height:1px;overflow:hidden;" aria-hidden="true">
          <label for="r_website">Website (do not fill)</label>
          <input id="r_website" name="website" type="text" tabindex="-1" autocomplete="off"/>
        </div>

        <p style="font-size:11px;color:rgba(240,237,228,0.5);margin:0 0 14px;"><span style="color:#e2574c;font-weight:700;">*</span> は必須項目です / Required fields</p>
        <div style="margin-bottom:16px;"><label style="display:block;font-size:10px;letter-spacing:0.15em;color:rgba(201,169,110,0.7);text-transform:uppercase;margin-bottom:6px;">お名前 / Name <span style="color:#e2574c;font-weight:700;margin-left:2px;">*</span></label><input id="r_name" type="text" placeholder="Yamada Taro" autocomplete="name" style="width:100%;background:#1a1a1a;border:1px solid rgba(201,169,110,0.25);border-radius:8px;padding:10px 14px;color:#f0ede4;font-size:16px;box-sizing:border-box;-webkit-appearance:none;"/></div>
        <div style="margin-bottom:16px;"><label style="display:block;font-size:10px;letter-spacing:0.15em;color:rgba(201,169,110,0.7);text-transform:uppercase;margin-bottom:6px;">メールアドレス / Email <span style="color:#e2574c;font-weight:700;margin-left:2px;">*</span></label><input id="r_email" type="email" placeholder="example@email.com" autocomplete="email" style="width:100%;background:#1a1a1a;border:1px solid rgba(201,169,110,0.25);border-radius:8px;padding:10px 14px;color:#f0ede4;font-size:16px;box-sizing:border-box;-webkit-appearance:none;"/></div>
        <div style="margin-bottom:16px;"><label style="display:block;font-size:10px;letter-spacing:0.15em;color:rgba(201,169,110,0.7);text-transform:uppercase;margin-bottom:6px;">電話番号 / Phone <span style="color:#e2574c;font-weight:700;margin-left:2px;">*</span></label><input id="r_phone" type="tel" placeholder="+81 90-0000-0000" autocomplete="tel" style="width:100%;background:#1a1a1a;border:1px solid rgba(201,169,110,0.25);border-radius:8px;padding:10px 14px;color:#f0ede4;font-size:16px;box-sizing:border-box;-webkit-appearance:none;"/></div>
        <div style="margin-bottom:16px;"><label style="display:block;font-size:10px;letter-spacing:0.15em;color:rgba(201,169,110,0.7);text-transform:uppercase;margin-bottom:6px;">紹介者 / Referred by</label><input id="r_referrer" type="text" placeholder="Optional" autocomplete="off" style="width:100%;background:#1a1a1a;border:1px solid rgba(201,169,110,0.25);border-radius:8px;padding:10px 14px;color:#f0ede4;font-size:16px;box-sizing:border-box;-webkit-appearance:none;"/></div>

        <div style="margin-bottom:16px;">
          <label style="display:block;font-size:10px;letter-spacing:0.15em;color:rgba(201,169,110,0.7);text-transform:uppercase;margin-bottom:8px;">コース / Course <span style="color:#e2574c;font-weight:700;margin-left:2px;">*</span></label>
          <button type="button" id="course-trigger" onclick="openCoursePicker()" style="width:100%;background:#1a1a1a;border:1px solid rgba(201,169,110,0.25);border-radius:8px;padding:13px 14px;color:#f0ede4;font-size:14px;box-sizing:border-box;text-align:left;cursor:pointer;display:flex;align-items:center;justify-content:space-between;gap:10px;">
            <span id="course-trigger-label" style="color:rgba(240,237,228,0.5);">コースを選択 / Select a course</span>
            <span style="color:#c9a96e;font-size:12px;flex-shrink:0;">▼</span>
          </button>
          <input type="hidden" id="r_course" value=""/>
          <p style="font-size:10px;color:rgba(240,237,228,0.4);margin:6px 0 0;line-height:1.5;">価格は1名様あたり / Prices are per person. All dishes Muslim-friendly.</p>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px;">
          <div><label style="display:block;font-size:10px;letter-spacing:0.15em;color:rgba(201,169,110,0.7);text-transform:uppercase;margin-bottom:6px;">人数 / Guests <span style="color:#e2574c;font-weight:700;margin-left:2px;">*</span></label><select id="r_guests" style="width:100%;background:#1a1a1a;border:1px solid rgba(201,169,110,0.25);border-radius:8px;padding:10px 14px;color:#f0ede4;font-size:16px;box-sizing:border-box;-webkit-appearance:none;"><option value="">-</option>{% for n in range(1, (store.max_guests or 8) + 1) %}<option>{{ n }}</option>{% endfor %}</select></div>
          <div><label style="display:block;font-size:10px;letter-spacing:0.15em;color:rgba(201,169,110,0.7);text-transform:uppercase;margin-bottom:6px;">希望時間 / Time <span style="color:#e2574c;font-weight:700;margin-left:2px;">*</span></label><select id="r_time" style="width:100%;background:#1a1a1a;border:1px solid rgba(201,169,110,0.25);border-radius:8px;padding:10px 14px;color:#f0ede4;font-size:16px;box-sizing:border-box;-webkit-appearance:none;"><option value="">-</option>{% for t in store.time_slots %}<option value="{{ t }}">{{ t }}</option>{% endfor %}</select></div>
        </div>

        <div style="margin-bottom:16px;">
          <label style="display:block;font-size:10px;letter-spacing:0.15em;color:rgba(201,169,110,0.7);text-transform:uppercase;margin-bottom:6px;">希望日 / Preferred Date <span style="color:#e2574c;font-weight:700;margin-left:2px;">*</span></label>
          <div style="position:relative;" onclick="document.getElementById('r_date').showPicker ? document.getElementById('r_date').showPicker() : document.getElementById('r_date').focus();">
            <input id="r_date" type="date" style="width:100%;background:#1a1a1a;border:1px solid rgba(201,169,110,0.25);border-radius:8px;padding:12px 40px 12px 14px;color:#f0ede4;font-size:16px;box-sizing:border-box;-webkit-appearance:none;cursor:pointer;" onclick="event.stopPropagation(); this.showPicker && this.showPicker();"/>
            <svg style="position:absolute;right:14px;top:50%;transform:translateY(-50%);width:18px;height:18px;color:#c9a96e;pointer-events:none;" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5"/>
            </svg>
          </div>
          <p style="font-size:10px;color:rgba(240,237,228,0.4);margin:4px 0 0;">📅 タップしてカレンダーから日付を選択 / Tap to pick from calendar</p>
          <p id="r_date_note" style="display:none;font-size:10px;color:#e57373;margin:6px 0 0;line-height:1.5;"></p>
          {% if store.tel_raw and store.tel_raw != "TBD" %}
          <a href="tel:{{ store.tel_raw }}" data-ga-event="tel_click" data-ga-location="reserve_form_sameday"
             style="display:flex;align-items:center;gap:8px;margin-top:10px;background:rgba(201,169,110,0.08);border:1px solid rgba(201,169,110,0.3);border-radius:8px;padding:10px 12px;text-decoration:none;">
            <span style="flex-shrink:0;width:26px;height:26px;border-radius:50%;background:rgba(201,169,110,0.18);display:flex;align-items:center;justify-content:center;">
              <svg style="width:14px;height:14px;color:#c9a96e;" fill="currentColor" viewBox="0 0 24 24"><path d="M6.62 10.79a15.15 15.15 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1.02-.24 11.36 11.36 0 0 0 3.57.57 1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1 11.36 11.36 0 0 0 .57 3.57 1 1 0 0 1-.24 1.02l-2.21 2.2z"/></svg>
            </span>
            <span style="line-height:1.35;">
              <span style="display:block;font-size:11px;color:#c9a96e;font-weight:600;letter-spacing:0.04em;">本日のご予約はお電話で / Same-day? Call us</span>
              <span style="display:block;font-size:12px;color:#f0ede4;letter-spacing:0.04em;">{{ store.tel_display }}</span>
            </span>
          </a>
          {% endif %}
        </div>

        <div style="margin-bottom:20px;"><label style="display:block;font-size:10px;letter-spacing:0.15em;color:rgba(201,169,110,0.7);text-transform:uppercase;margin-bottom:6px;">ご要望 / Special Requests</label><textarea id="r_message" rows="3" placeholder="Allergies, dietary requirements, special occasions..." style="width:100%;background:#1a1a1a;border:1px solid rgba(201,169,110,0.25);border-radius:8px;padding:10px 14px;color:#f0ede4;font-size:16px;box-sizing:border-box;resize:vertical;-webkit-appearance:none;"></textarea></div>

        <p id="r_error" style="color:#e57373;font-size:12px;margin-bottom:12px;display:none;"></p>
        <button onclick="openConfirmDialog()" id="r_submit" style="width:100%;background:#c9a96e;color:#090909;font-family:'Josefin Sans',sans-serif;font-weight:700;font-size:13px;letter-spacing:0.15em;text-transform:uppercase;padding:14px;border:none;border-radius:8px;cursor:pointer;">SEND REQUEST / 送信する</button>

      </div>

      {# Success screen — shown after EmailJS send succeeds #}
      <div id="reserveSuccess" style="display:none;">
        <div style="text-align:center;padding:24px 12px;">
          <div style="width:54px;height:54px;margin:0 auto 18px;border-radius:50%;border:1.5px solid rgba(201,169,110,0.6);display:flex;align-items:center;justify-content:center;">
            <span style="color:#c9a96e;font-size:26px;line-height:1;">✓</span>
          </div>
          <h4 style="font-family:'Noto Serif JP',serif;font-size:18px;color:#c9a96e;margin:0 0 6px;letter-spacing:0.08em;">ご予約リクエストを承りました</h4>
          <p style="font-size:12px;color:rgba(201,169,110,0.7);margin:0 0 20px;letter-spacing:0.1em;">Request Received</p>
          <div style="max-width:300px;margin:0 auto;padding:16px 20px;background:rgba(201,169,110,0.05);border:1px solid rgba(201,169,110,0.2);border-radius:12px;">
            <p style="font-size:13px;color:rgba(240,237,228,0.8);margin:0 0 10px;line-height:1.7;">
              {{ stores.brand.brand_name }} からの確定メールをお待ちください。
            </p>
            <p style="font-size:12px;color:rgba(240,237,228,0.55);margin:0;line-height:1.6;">
              Please wait for a confirmation from {{ stores.brand.brand_name }}.
            </p>
          </div>
          <button onclick="closeReserveModal()" style="margin-top:24px;background:transparent;border:1px solid rgba(201,169,110,0.5);color:#c9a96e;font-size:11px;letter-spacing:0.2em;padding:11px 32px;border-radius:8px;cursor:pointer;">CLOSE</button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ============================================================

<!-- EmailJS SDK -->
<script src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js"></script>

<script>
(function(){
  // ============================================================
  // Store-specific config injected from _data/stores.js
  // ============================================================
  var EMAILJS_CFG = {
    public_key:        '{{ store.form_config.emailjs.public_key }}',
    service_id:        '{{ store.form_config.emailjs.service_id }}',
    template_id_owner: '{{ store.form_config.emailjs.template_id_owner }}',
    template_id_guest: '{{ store.form_config.emailjs.template_id_guest }}'
  };
  var STORE_INFO = {
    location:     '{{ store.name_jp }}',
    location_key: '{{ store.slug }}',
    address_jp:   '{{ store.address_jp_line1 }}',
    address_en:   '{{ store.address_en_line1 }}'
  };
  // 当日予約の受付可否（store.same_day_reserve が false なら当日は電話案内）
  var SAME_DAY_RESERVE = ('{{ store.same_day_reserve }}' === 'true');
  var TIME_SLOTS = [{% for t in store.time_slots %}'{{ t }}'{% if not loop.last %},{% endif %}{% endfor %}];

  // 選択された日付に応じて時間枠の選択可否を更新する。
  // 当日(today)を選んだ場合：現在時刻を過ぎた枠は無効化（SAME_DAY_RESERVE時のみ当日選択可）。
  // 明日以降：全枠を有効化。
  function refreshTimeOptions_(dateStr) {
    var sel = document.getElementById('r_time');
    if (!sel) return;
    var now = new Date();
    var y = now.getFullYear() + '-' + String(now.getMonth()+1).padStart(2,'0') + '-' + String(now.getDate()).padStart(2,'0');
    var isToday = (dateStr === y);
    var nowMin = now.getHours() * 60 + now.getMinutes();
    // option を作り直す
    var current = sel.value;
    var html = '<option value="">-</option>';
    var firstEnabled = '';
    TIME_SLOTS.forEach(function(t) {
      var parts = t.split(':');
      var slotMin = parseInt(parts[0],10) * 60 + parseInt(parts[1]||'0',10);
      // 当日は「現在時刻以降」の枠のみ有効（同分はぎりぎり不可にして余裕を持たせる）
      var disabled = isToday && slotMin <= nowMin;
      if (!disabled && !firstEnabled) firstEnabled = t;
      html += '<option value="' + t + '"' + (disabled ? ' disabled' : '') + '>' + t + (disabled ? '（受付終了 / closed）' : '') + '</option>';
    });
    sel.innerHTML = html;
    // 以前の選択が無効になっていたらクリア
    var stillValid = current && TIME_SLOTS.indexOf(current) !== -1 && !(isToday && (parseInt(current.split(':')[0],10)*60 + parseInt(current.split(':')[1]||'0',10)) <= nowMin);
    sel.value = stillValid ? current : '';
  }
  var TEL_DISPLAY = '{{ store.tel_display }}';
  var TEL_RAW = '{{ store.tel_raw }}';

  var BLOCKED_DATES = [];
  {% if store.form_config and store.form_config.blocked_dates %}
    {% for d in store.form_config.blocked_dates %}
  BLOCKED_DATES.push('{{ d }}');
    {% endfor %}
  {% endif %}

  // Initialize EmailJS
  if (typeof emailjs !== 'undefined' && EMAILJS_CFG.public_key) {
    emailjs.init(EMAILJS_CFG.public_key);
  }

  // ===== Phase 2: 上限・空き状況（GAS Web App） =====
  var GAS_ENDPOINT = '{{ stores.brand.gas_endpoint or "" }}';

  async function refreshAvailability() {
    var date = document.getElementById('r_date').value;
    var timeSel = document.getElementById('r_time');
    if (!date || !timeSel || !GAS_ENDPOINT) return;
    try {
      var res = await fetch(GAS_ENDPOINT + '?store=' + encodeURIComponent(STORE_INFO.location_key) + '&date=' + encodeURIComponent(date));
      var json = await res.json();
      if (!json || !json.ok) return;
      Array.prototype.forEach.call(timeSel.options, function (opt) {
        if (!opt.value) return;
        var slot = json.slots[opt.value];
        if (!slot) return;
        if (slot.full) {
          opt.disabled = true;
          opt.textContent = opt.value + '（満席 / Full）';
          if (timeSel.value === opt.value) timeSel.value = '';
        } else {
          opt.disabled = false;
          opt.textContent = opt.value;   // 残り枠は表示しない
        }
      });
    } catch (err) { console.warn('availability fetch failed', err); }
  }

  document.addEventListener('DOMContentLoaded', function () {
    var di = document.getElementById('r_date');
    if (di) di.addEventListener('change', function () {
      if (BLOCKED_DATES.length && BLOCKED_DATES.indexOf(this.value) !== -1) return;
      refreshAvailability();
    });
  });

  // ============================================================
  // Course card radio selection
  // ============================================================
  // ============================================================
  // Course picker (sub-modal with cards + collapsible details)
  // ============================================================
  var PRICE_ADJUST = parseInt('{{ store.price_adjust or 0 }}', 10) || 0;
  function cpYen_(n){ return '¥' + n.toLocaleString('en-US'); }
  function cpPrice_(base){ return cpYen_(base + PRICE_ADJUST); }
  function cpTax_(base){ return cpYen_(Math.floor((base + PRICE_ADJUST) * 1.1)); }
  var CP_COURSES = [
    { id:'sushi-standard', cat:'sushi', name:'Sushi Course Standard', base:54800, meta:'8 courses · 60–75 min',
      rows:[['序','Chilled Tofu',0],['八寸','Sushi Appetizer Plate — Seared Salmon / Marinated Tuna / Dashimaki Tamago / Miso Cream Cheese / Edamame',0],['鮨','Temaki: Salmon & Ikura · Nigiri 3 kinds (Tuna / Salmon / White Fish) · Nigiri 3 kinds (Seared Salmon / Tamago / Sushi) · Hand-Served Sushi',1],['椀','Aka-dashi Miso Soup — Lake Shinji Clams',0],['茶と甘味','Matcha Experience & Dessert — Tsujiri · Mini Japanese Sweets',0]] },
    { id:'sushi-premium', cat:'sushi', name:'Sushi Course Premium', base:74800, meta:'8 courses · 60–75 min', popular:true,
      rows:[['序','Chilled Tofu',0],['八寸','Premium Sushi Appetizer Plate — Seared Salmon / Marinated Tuna / Mini Ikura Bowl / Dashimaki Tamago / Miso Cream Cheese',0],['鮨','Temaki: Sea Urchin · Temaki: Salmon & Ikura · Nigiri 3 kinds (Tuna / Salmon / White Fish) · Nigiri 3 kinds (Urchin Gunkan / Ikura Gunkan / Seared Sushi)',1],['椀','Aka-dashi Miso Soup — Lake Shinji Clams',0],['茶と甘味','Matcha Experience & Dessert — Tsujiri · Mini Japanese Sweets',0]] },
    { id:'sushi-wagyu-standard', cat:'mix', name:'Sushi & Wagyu Course Standard', base:64800, meta:'8 courses · 60–75 min',
      rows:[['序','Chilled Tofu',0],['八寸','Appetizer Plate — Wagyu Roast Beef / Seared Salmon / Marinated Tuna / Dashimaki Tamago / Miso Cream Cheese',0],['鮨','Temaki: Salmon & Ikura · Nigiri 3 kinds (Tuna / Salmon / White Fish)',0],['温物','Wagyu Shabu-shabu & Dashi',0],['逸品','Wagyu Fillet Spring Roll',0],['和牛','Hand-Served Wagyu Sushi',1],['茶と甘味・椀','Matcha & Dessert — Tsujiri · Aka-dashi Miso Soup — Lake Shinji Clams',0]] },
    { id:'sushi-kobe-premium', cat:'mix', name:'Sushi & Kobe Beef Course Premium', base:84800, meta:'8 courses · 60–75 min',
      rows:[['序','Chilled Tofu',0],['八寸','Kobe Beef Appetizer Plate — Wagyu Roast Beef / Seared Salmon / Marinated Tuna / Dashimaki Tamago / Miso Cream Cheese',0],['鮨','Temaki: Sea Urchin · Nigiri 3 kinds (Tuna / Salmon / Ikura Gunkan)',0],['温物','Kobe Beef Shabu-shabu & Dashi',0],['逸品','Kobe Beef Steak',1],['神戸牛','Seared Kobe Beef Nigiri',1],['茶と甘味・椀','Matcha & Dessert — Tsujiri · Aka-dashi Miso Soup — Lake Shinji Clams',0]] }
  ];
  var CP_CATCOLOR = { sushi:'#5dc9b0', wagyu:'#d36a5a', mix:'#c9a96e' };
  var CP_CATLABEL = { sushi:'Sushi', wagyu:'Wagyu / Beef', mix:'Sushi & Wagyu' };

  function cpBuildCards(){
    var wrap = document.getElementById('cp-cards');
    if (!wrap || wrap.dataset.built === '1') return;
    var html = '';
    CP_COURSES.forEach(function(c){
      var col = CP_CATCOLOR[c.cat];
      var rows = c.rows.map(function(r){
        var cls = r[2] ? 'cp-row-hl' : 'cp-row-txt';
        var tag = r[2] ? ' <span class="cp-sig">Signature</span>' : '';
        return '<div class="cp-row"><span class="cp-row-label">'+r[0]+'</span><span class="'+cls+'">'+r[1]+tag+'</span></div>';
      }).join('');
      html += '<div class="cp-card'+(c.popular?' cp-pop':'')+'" style="--cpcol:'+col+';">'
        + '<div class="cp-bar"></div>'
        + (c.popular?'<div class="cp-pop-tag">MOST POPULAR</div>':'')
        + '<div class="cp-body">'
        + '<span class="cp-badge">'+CP_CATLABEL[c.cat]+'</span>'
        + '<div class="cp-name">'+c.name+'</div>'
        + '<div class="cp-price"><span class="cp-price-main">'+cpPrice_(c.base)+'</span><span class="cp-price-tax">('+cpTax_(c.base)+' incl.tax)</span></div>'
        + '<div class="cp-meta">'+c.meta+'</div>'
        + '<button type="button" class="cp-detbtn" data-toggle="'+c.id+'">詳細を見る / SEE DETAILS</button>'
        + '<div class="cp-detail" id="cp-detail-'+c.id+'"><div class="cp-detail-inner">'+rows+'</div></div>'
        + '<button type="button" class="cp-select" data-choose="'+c.id+'">このコースを選ぶ / SELECT</button>'
        + '</div></div>';
    });
    wrap.innerHTML = html;
    wrap.dataset.built = '1';
    wrap.addEventListener('click', function(e){
      var t = e.target.closest('[data-toggle]');
      if (t){ cpToggle(t.getAttribute('data-toggle')); return; }
      var s = e.target.closest('[data-choose]');
      if (s){ cpChoose(s.getAttribute('data-choose')); }
    });
  }
  window.cpToggle = function(id){
    var d = document.getElementById('cp-detail-'+id);
    if (!d) return;
    d.style.maxHeight = (d.style.maxHeight && d.style.maxHeight !== '0px') ? '0px' : (d.scrollHeight + 40)+'px';
  };
  window.cpChoose = function(id){
    var c = CP_COURSES.filter(function(x){return x.id===id;})[0];
    if (!c) return;
    var val = c.name + ' - ' + cpPrice_(c.base) + ' (' + cpTax_(c.base) + ' incl.tax) / ' + c.meta;
    document.getElementById('r_course').value = val;
    var lbl = document.getElementById('course-trigger-label');
    if (lbl){ lbl.textContent = c.name + '  ' + cpPrice_(c.base); lbl.style.color = '#f0ede4'; }
    closeCoursePicker();
  };
  window.openCoursePicker = function(){
    cpBuildCards();
    document.getElementById('coursePicker').style.display = 'block';
    document.body.style.overflow = 'hidden';
  };
  window.closeCoursePicker = function(){
    document.getElementById('coursePicker').style.display = 'none';
    // 親モーダルが開いているので body は hidden のままでよい
  };
  // 互換: 旧 selectCourse 呼び出しが残っていても落ちないように
  window.selectCourse = function(courseId){ if (window.cpChoose) window.cpChoose(courseId); };

  // ============================================================
  // Open / Close modal
  // ============================================================
  window.openReserveModal = function(label, preselectCourseId) {
    document.getElementById('reserveModal').style.display = 'block';
    document.body.style.overflow = 'hidden';
    window._reserveModalOpenedAt = Date.now();

    var today = new Date();
    function ymd_(d){ return d.getFullYear() + '-' + String(d.getMonth()+1).padStart(2,'0') + '-' + String(d.getDate()).padStart(2,'0'); }
    // 当日予約OFF: 最短でも明日から選べるようにする
    var minD = new Date(today.getFullYear(), today.getMonth(), today.getDate());
    if (!SAME_DAY_RESERVE) { minD.setDate(minD.getDate() + 1); }
    // 先頭の連続した予約不可日(工事休業等)はスキップし、最初に選べる日を min に設定
    var _g = 0;
    while (BLOCKED_DATES.indexOf(ymd_(minD)) !== -1 && _g < 366) { minD.setDate(minD.getDate() + 1); _g++; }
    document.getElementById('r_date').setAttribute('min', ymd_(minD));

    // GA4 event
    if (typeof gtag === 'function') {
      gtag('event', 'reserve_modal_open', {
        'event_category': 'engagement',
        'event_label': label,
        'store_name': '{{ store.slug }}',
        'store_area': '{{ store.region }}',
        'brand': '{{ stores.brand.brand_slug }}',
        'channel': '{{ store.channel_id }}'
      });
    }
    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({
      event: 'reserve_modal_open',
      reserve_button_location: label
    });

    // カードの「Reserve」から開かれた場合：そのコースを事前選択
    if (preselectCourseId && window.cpChoose) {
      window.cpChoose(preselectCourseId);
      if (typeof gtag === 'function') {
        gtag('event', 'course_preselect', {
          'event_category': 'engagement',
          'event_label': preselectCourseId,
          'store_name': '{{ store.slug }}',
          'store_area': '{{ store.region }}',
          'brand': '{{ stores.brand.brand_slug }}',
          'channel': '{{ store.channel_id }}'
        });
      }
    } else {
      var rc = document.getElementById('r_course');
      if (rc) rc.value = '';
      var ctl0 = document.getElementById('course-trigger-label');
      if (ctl0) { ctl0.textContent = 'コースを選択 / Select a course'; ctl0.style.color = 'rgba(240,237,228,0.5)'; }
    }
  };

  window.closeReserveModal = function() {
    document.getElementById('reserveModal').style.display = 'none';
    document.getElementById('confirmDialog').style.display = 'none';
    document.body.style.overflow = '';
    document.getElementById('reserveForm').style.display = 'block';
    document.getElementById('reserveSuccess').style.display = 'none';
    var brushReset = document.getElementById('sumiBrushSvg');
    if (brushReset) brushReset.classList.remove('drawing');
    ['r_name','r_email','r_phone','r_referrer','r_course','r_guests','r_time','r_date','r_message','r_website'].forEach(function(id){
      var el = document.getElementById(id);
      if (el) el.value = '';
    });
    var ctl = document.getElementById('course-trigger-label');
    if (ctl){ ctl.textContent = 'コースを選択 / Select a course'; ctl.style.color = 'rgba(240,237,228,0.5)'; }
    var cd1 = document.getElementById('confirm_check_details');
    var cd2 = document.getElementById('confirm_check_policy');
    if (cd1) cd1.checked = false;
    if (cd2) cd2.checked = false;
    var err = document.getElementById('r_error');
    if (err) { err.style.display = 'none'; err.textContent = ''; }
    var btn = document.getElementById('r_submit');
    if (btn) { btn.textContent = 'SEND REQUEST / 送信する'; btn.disabled = false; }
  };

  // ============================================================
  // Date validation against blocked dates
  // ============================================================
  document.addEventListener('DOMContentLoaded', function() {
    var dateInput = document.getElementById('r_date');
    if (dateInput) {
      dateInput.addEventListener('change', function() {
        var note = document.getElementById('r_date_note');
        if (this.value && BLOCKED_DATES.indexOf(this.value) !== -1) {
          this.value = '';
          if (note) { note.textContent = '※ その日は予約を受付しておりません。別の日をお選びください / That date is unavailable. Please choose another date.'; note.style.display = 'block'; }
        } else if (note) {
          note.style.display = 'none';
        }
        // 当日選択時は現在時刻以降の枠だけ有効化（新宿などsame-day可の店向け）
        refreshTimeOptions_(this.value);
      });
    }
  });

  // ============================================================
  // Open confirmation dialog
  // ============================================================
  window.openConfirmDialog = function() {
    var name    = document.getElementById('r_name').value.trim();
    var email   = document.getElementById('r_email').value.trim();
    var phone   = document.getElementById('r_phone').value.trim();
    var course  = document.getElementById('r_course').value;
    var guests  = document.getElementById('r_guests').value;
    var time    = document.getElementById('r_time').value;
    var date    = document.getElementById('r_date').value;
    var website = document.getElementById('r_website').value.trim();
    var errEl   = document.getElementById('r_error');

    // Honeypot trip → silently "succeed"
    if (website !== '') {
      document.getElementById('reserveForm').style.display = 'none';
      document.getElementById('reserveSuccess').style.display = 'block';
      var brushSvg1 = document.getElementById('sumiBrushSvg');
      if (brushSvg1) { brushSvg1.classList.remove('drawing'); void brushSvg1.offsetWidth; brushSvg1.classList.add('drawing'); }
      return;
    }
    // Speed-trap: submitted too quickly → silent success
    var openedAt = window._reserveModalOpenedAt || 0;
    if (Date.now() - openedAt < 3000) {
      document.getElementById('reserveForm').style.display = 'none';
      document.getElementById('reserveSuccess').style.display = 'block';
      var brushSvg2 = document.getElementById('sumiBrushSvg');
      if (brushSvg2) { brushSvg2.classList.remove('drawing'); void brushSvg2.offsetWidth; brushSvg2.classList.add('drawing'); }
      return;
    }

    if (!name || !email || !phone || !course || !guests || !time || !date) {
      errEl.textContent = '* 必須項目を入力してください / Please fill in required fields.';
      errEl.style.display = 'block';
      return;
    }
    // 過去日（昨日以前）は受付不可（手入力対策。カレンダー側 min でも制限済み）
    var _n = new Date();
    var _todayStr = _n.getFullYear() + '-' + String(_n.getMonth()+1).padStart(2,'0') + '-' + String(_n.getDate()).padStart(2,'0');
    if (date < _todayStr) {
      errEl.textContent = '※ 過去の日付は選択できません / Please choose today or a future date.';
      errEl.style.display = 'block';
      return;
    }
    // 当日予約OFFのとき、今日の日付なら電話案内へ
    if (!SAME_DAY_RESERVE) {
      var _t = new Date();
      var _today = _t.getFullYear() + '-' + String(_t.getMonth()+1).padStart(2,'0') + '-' + String(_t.getDate()).padStart(2,'0');
      if (date === _today) {
        errEl.innerHTML = '本日のご予約はお電話で承ります / For same-day reservations, please call us'
          + (TEL_DISPLAY ? ': <a href="tel:' + TEL_RAW + '" style="color:#c9a96e;text-decoration:underline;">' + TEL_DISPLAY + '</a>' : '.');
        errEl.style.display = 'block';
        return;
      }
    } else {
      // 当日予約OKの店：今日を選んだ場合、現在時刻を過ぎた枠は不可
      var _tn = new Date();
      var _td = _tn.getFullYear() + '-' + String(_tn.getMonth()+1).padStart(2,'0') + '-' + String(_tn.getDate()).padStart(2,'0');
      if (date === _td) {
        var _nowMin = _tn.getHours() * 60 + _tn.getMinutes();
        var _slotMin = parseInt(time.split(':')[0],10) * 60 + parseInt(time.split(':')[1]||'0',10);
        if (_slotMin <= _nowMin) {
          errEl.textContent = '※ 本日のこの時間枠は受付を終了しました。別の時間または日付をお選びください / This time slot has closed for today. Please choose another time or date.';
          errEl.style.display = 'block';
          return;
        }
      }
    }
    if (BLOCKED_DATES.indexOf(date) !== -1) {
      errEl.textContent = '※ 選択された日付は予約を受付しておりません / The selected date is unavailable.';
      errEl.style.display = 'block';
      return;
    }
    errEl.style.display = 'none';

    var dateObj = new Date(date);
    var weekdays = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
    var formattedDate = dateObj.getFullYear() + '/' +
                        String(dateObj.getMonth()+1).padStart(2,'0') + '/' +
                        String(dateObj.getDate()).padStart(2,'0') +
                        ' (' + weekdays[dateObj.getDay()] + ')';

    document.getElementById('confirm_date').textContent = formattedDate;
    document.getElementById('confirm_time').textContent = time;
    document.getElementById('confirm_guests').textContent = guests + (guests === '1' ? ' guest' : ' guests');
    document.getElementById('confirm_course').textContent = course.split(' - ')[0];

    document.getElementById('confirm_check_details').checked = false;
    document.getElementById('confirm_check_policy').checked = false;
    document.getElementById('confirm_error').style.display = 'none';

    document.getElementById('confirmDialog').style.display = 'block';
  };

  window.closeConfirmDialog = function() {
    document.getElementById('confirmDialog').style.display = 'none';
  };

  // ============================================================
  // Submit via EmailJS
  // ============================================================
  window.confirmAndSubmit = async function() {
    var checkDetails = document.getElementById('confirm_check_details').checked;
    var checkPolicy  = document.getElementById('confirm_check_policy').checked;
    var errEl = document.getElementById('confirm_error');
    var btnHtml = 'この内容で送信<br/><span style="font-size:9px;opacity:0.75;">CONFIRM &amp; SEND</span>';

    if (!checkDetails || !checkPolicy) {
      errEl.textContent = '両方にチェックを入れてください / Please check both boxes.';
      errEl.style.display = 'block';
      return;
    }
    errEl.style.display = 'none';

    var btn = document.getElementById('confirm_submit_btn');
    btn.textContent = 'Sending...';
    btn.disabled = true;

    var refEl = document.getElementById('r_referrer');
    var params = {
      name:    document.getElementById('r_name').value.trim(),
      email:   document.getElementById('r_email').value.trim(),
      phone:   document.getElementById('r_phone').value.trim(),
      referrer: refEl ? refEl.value.trim() : '',
      course:  document.getElementById('r_course').value,
      guests:  document.getElementById('r_guests').value,
      time:    document.getElementById('r_time').value,
      date:    document.getElementById('r_date').value,
      message: document.getElementById('r_message').value.trim(),
      source_path:  window.location.pathname,
      store_slug:   STORE_INFO.location_key,
      location:     STORE_INFO.location,
      location_key: STORE_INFO.location_key,
      address_jp:   STORE_INFO.address_jp,
      address_en:   STORE_INFO.address_en
    };

    // Phase 2: 上限判定（GAS_ENDPOINTが空なら従来どおりメール送信のみ）
    if (GAS_ENDPOINT) {
      var capRes;
      try {
        var capResp = await fetch(GAS_ENDPOINT, {
          method: 'POST',
          headers: { 'Content-Type': 'text/plain;charset=utf-8' },
          body: JSON.stringify(params)
        });
        capRes = await capResp.json();
      } catch (e) {
        errEl.textContent = '空き状況の確認に失敗しました。通信環境をご確認のうえ、もう一度お試しください。';
        errEl.style.display = 'block';
        btn.innerHTML = btnHtml; btn.disabled = false;
        return;
      }
      if (!capRes || !capRes.ok) {
        errEl.textContent = (capRes && capRes.reason === 'full')
          ? '申し訳ございません。選択された時間枠は満席です。別の時間をお選びください。/ This time slot is fully booked.'
          : 'エラーが発生しました。再度お試しください。/ Please try again.';
        errEl.style.display = 'block';
        btn.innerHTML = btnHtml; btn.disabled = false;
        if (typeof refreshAvailability === 'function') await refreshAvailability();
        return;
      }
      params.booking_id = capRes.booking_id;
    }

    // 確定済み。メールは待たずにバックグラウンド送信（予約はdoPostで確定済み → SENDINGの固まり防止）
    if (typeof emailjs !== 'undefined' && EMAILJS_CFG.public_key) {
      emailjs.send(EMAILJS_CFG.service_id, EMAILJS_CFG.template_id_owner, params)
        .catch(function (e) { console.warn('owner mail failed:', e); });
      emailjs.send(EMAILJS_CFG.service_id, EMAILJS_CFG.template_id_guest, params)
        .catch(function (e) { console.warn('guest mail failed:', e); });
    }

    if (typeof gtag === 'function') {
      gtag('event', 'reservation_form_submit', {
        'event_category': 'conversion',
        'form_guests': params.guests,
        'form_date': params.date,
        'form_course': params.course,
        'store_name': '{{ store.slug }}',
        'store_area': '{{ store.region }}',
        'brand': '{{ stores.brand.brand_slug }}',
        'channel': '{{ store.channel_id }}'
      });
    }
    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({
      event: 'reservation_form_submit',
      form_guests: params.guests,
      form_date: params.date,
      form_course: params.course,
      source_path: params.source_path,
      booking_id: params.booking_id || ''
    });

    {% if store.gads_conversion %}
    if (typeof gtag === 'function') {
      gtag('event', 'conversion', {
        'send_to': '{{ store.gads_conversion }}'
      });
    }
    {% endif %}

    document.getElementById('confirmDialog').style.display = 'none';
    document.getElementById('reserveForm').style.display = 'none';
    document.getElementById('reserveSuccess').style.display = 'block';
    var brushSvg = document.getElementById('sumiBrushSvg');
    if (brushSvg) {
      brushSvg.classList.remove('drawing');
      void brushSvg.offsetWidth;
      brushSvg.classList.add('drawing');
    }
  };

  // ============================================================
  // Close modal by clicking outside
  // ============================================================
  document.addEventListener('DOMContentLoaded', function() {
    var m = document.getElementById('reserveModal');
    if (m) m.addEventListener('click', function(e){ if (e.target === this) closeReserveModal(); });
    var cd = document.getElementById('confirmDialog');
    if (cd) cd.addEventListener('click', function(e){ if (e.target === this) closeConfirmDialog(); });
  });
})();
</script>

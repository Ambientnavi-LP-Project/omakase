      <div style="display:grid;grid-template-columns:1fr 1.2fr;gap:10px;">
        <button onclick="closeConfirmDialog()" style="background:transparent;border:1px solid rgba(201,169,110,0.4);color:rgba(201,169,110,0.9);font-family:'Josefin Sans',sans-serif;font-weight:600;font-size:11px;letter-spacing:0.15em;text-transform:uppercase;padding:13px 10px;border-radius:8px;cursor:pointer;">修正する<br/><span style="font-size:9px;opacity:0.7;">EDIT</span></button>
        <button onclick="confirmAndSubmit()" id="confirm_submit_btn" style="background:#c9a96e;color:#090909;font-family:'Josefin Sans',sans-serif;font-weight:700;font-size:11px;letter-spacing:0.15em;text-transform:uppercase;padding:13px 10px;border:none;border-radius:8px;cursor:pointer;">この内容で送信<br/><span style="font-size:9px;opacity:0.75;">CONFIRM &amp; SEND</span></button>

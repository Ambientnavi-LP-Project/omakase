      <div style="margin-bottom:20px;">
        <label style="display:flex;gap:10px;align-items:flex-start;cursor:pointer;padding:10px 0;">
          <input id="confirm_check_details" type="checkbox" class="confirm-checkbox"/>
          <span style="font-size:12px;color:rgba(240,237,228,0.75);line-height:1.5;">
            <strong style="color:rgba(201,169,110,0.9);font-weight:600;">日付・時間・人数を確認しました</strong><br/>
            <span style="color:rgba(240,237,228,0.55);font-size:11px;">I have confirmed the date, time and number of guests are correct.</span>
          </span>

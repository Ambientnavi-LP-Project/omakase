      <!-- キャンセルポリシー & 個人情報（確定画面に表示） -->
      <div style="background:rgba(201,169,110,0.05);border:1px solid rgba(201,169,110,0.2);border-radius:8px;padding:12px 14px;margin-bottom:12px;font-size:11px;color:rgba(240,237,228,0.5);line-height:1.7;">
        <p style="margin:0 0 6px;color:rgba(201,169,110,0.7);font-weight:600;">キャンセルポリシー / Cancellation Policy</p>
        <p style="margin:0 0 4px;">・24時間前以内：¥10,000 / person &nbsp;|&nbsp; Within 24 hours: ¥10,000 / person</p>
        <p style="margin:0 0 10px;">・48時間前以内：¥5,000 / person &nbsp;|&nbsp; Within 48 hours: ¥5,000 / person</p>
        {% if store.tel_display != 'TBD' %}
        <hr style="border:none;border-top:1px solid rgba(201,169,110,0.15);margin:8px 0;"/>
        <p style="margin:0;color:rgba(240,237,228,0.6);font-weight:400;">* For urgent inquiries, please call us at <a href="tel:{{ store.tel_raw }}" style="color:#c9a96e;text-decoration:underline;">{{ store.tel_display }}</a>.</p>

---
pagination:
  data: stores.pagesTest
  size: 1
  alias: store
permalink: "/{{ store.region }}/{{ store.slug }}/{{ store.channel_suffix }}index.html"
eleventyComputed:
  title: "{{ store.name_full_en }}"
  is_reserve_ready: "{{ 'true' if store.tablecheck_url != 'TBD' else 'false' }}"
  is_form_reserve: "{{ 'true' if store.reserve_system == 'form' else 'false' }}"
  tablecheck_with_utm: "{% if store.tablecheck_url != 'TBD' %}{{ store.tablecheck_url }}?utm_source={{ store.channel_utm_source }}&utm_medium=referral{% else %}#{% endif %}"
---
<!DOCTYPE html>
<html class="scroll-smooth" lang="en">
<head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>{{ store.name_full_en }}</title>
<meta name="description" content="Muslim-friendly omakase featuring ultra-rare lean Wagyu and authentic Edomae sushi in {{ store.city }}. Alcohol-free menu, crafted for everyone.">
{% if store.channel_id != "default" %}
<meta name="robots" content="noindex,follow">
<link rel="canonical" href="https://{{ stores.brand.domain }}/{{ store.region }}/{{ store.slug }}/">
{% endif %}

<!-- Google tag (gtag.js) - GA4 -->
<script async src="https://www.googletagmanager.com/gtag/js?id={{ stores.brand.ga4_id }}"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', '{{ stores.brand.ga4_id }}', {
    'store_name': '{{ store.slug }}',
    'store_area': '{{ store.region }}',
    'brand': '{{ stores.brand.brand_slug }}',
    'channel': '{{ store.channel_id }}'
  });
</script>

{% if store.gads_id %}
<!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id={{ store.gads_id }}"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', '{{ store.gads_id }}');
</script>
{% endif %}

<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>

<link href="https://fonts.googleapis.com" rel="preconnect"/>
<link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect"/>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Epilogue:wght@300;400;600&family=Josefin+Sans:wght@300;400;600&family=Noto+Serif+JP:wght@300;400;600&display=swap" rel="stylesheet"/>

<script>
tailwind.config = {
  theme: {
    extend: {
      colors: {
        'ginza-gold': '#c9a96e',
        'ginza-black': '#090909',
        'ginza-ivory': '#f0ede4',
        'halal-green': '#0d1f10',
      },
      fontFamily: {
        'epilogue': ['Epilogue', 'sans-serif'],
        'cormorant': ['Cormorant Garamond', 'serif'],
        'josefin': ['Josefin Sans', 'sans-serif'],
      },
      animation: { 'ken-burns': 'kenburns 20s ease-in-out infinite alternate' },
      keyframes: {
        kenburns: { '0%': { transform:'scale(1)' }, '100%': { transform:'scale(1.15)' } }
      }
    }
  }
}
</script>

<style>
body { padding-bottom: 72px; }
.reveal { opacity:0; transform:translateY(30px); transition:all 0.8s ease-out; }
.reveal.active { opacity:1; transform:translateY(0); }
.dark-overlay { background:linear-gradient(to bottom,rgba(9,9,9,0.15) 0%,rgba(9,9,9,0.90) 100%); }
.nav-link { position:relative; font-size:10px; letter-spacing:0.2em; text-transform:uppercase; color:rgba(240,237,228,0.6); transition:color 0.3s; }
.nav-link::after { content:''; position:absolute; left:0; bottom:-2px; width:0; height:1px; background:#c9a96e; transition:width 0.3s; }
.nav-link:hover { color:#c9a96e; }
.nav-link:hover::after { width:100%; }
.header-divider { width:1px; height:14px; background:rgba(201,169,110,0.3); }
.sticky-cta { position:fixed; bottom:0; left:0; right:0; z-index:100; background:rgba(9,9,9,0.93); backdrop-filter:blur(12px); border-top:1px solid rgba(201,169,110,0.25); padding:12px 20px; display:flex; align-items:center; justify-content:space-between; gap:12px; }
.sticky-cta-text { font-size:11px; color:rgba(240,237,228,0.55); letter-spacing:0.05em; line-height:1.4; }
.sticky-cta-text strong { display:block; color:rgba(201,169,110,0.9); font-weight:600; font-size:12px; letter-spacing:0.08em; }
.sticky-cta-btn { flex-shrink:0; background:#c9a96e; color:#090909; font-family:'Josefin Sans',sans-serif; font-weight:700; font-size:11px; letter-spacing:0.15em; text-transform:uppercase; padding:12px 20px; border-radius:8px; white-space:nowrap; transition:transform 0.2s,opacity 0.2s; border:none; cursor:pointer; text-decoration:none; display:inline-flex; align-items:center; }
.sticky-cta-btn:hover { transform:scale(1.04); opacity:0.92; }
/* floating availability button (bottom-right) */
.float-cta{position:fixed;right:16px;bottom:16px;z-index:100;display:flex;flex-direction:column;align-items:flex-start;gap:2px;background:#c9a96e;color:#090909;border:none;cursor:pointer;text-decoration:none;border-radius:14px;padding:11px 18px;box-shadow:0 8px 28px rgba(0,0,0,0.45),0 0 0 1px rgba(201,169,110,0.5);transition:transform .2s,box-shadow .2s;animation:floatIn .6s ease both;}
.float-cta:hover{transform:translateY(-2px) scale(1.02);box-shadow:0 12px 34px rgba(0,0,0,0.55),0 0 0 1px rgba(201,169,110,0.7);}
@keyframes floatIn{0%{opacity:0;transform:translateY(20px);}100%{opacity:1;transform:translateY(0);}}
.float-cta-viewers{display:flex;align-items:center;gap:6px;font-family:'Josefin Sans',sans-serif;font-size:10px;font-weight:600;letter-spacing:0.06em;color:rgba(9,9,9,0.72);text-transform:uppercase;}
.float-dot{width:7px;height:7px;border-radius:50%;background:#16a34a;box-shadow:0 0 0 0 rgba(22,163,74,0.6);animation:pulseGreen 1.8s ease-in-out infinite;}
@keyframes pulseGreen{0%{box-shadow:0 0 0 0 rgba(22,163,74,0.6);}70%{box-shadow:0 0 0 7px rgba(22,163,74,0);}100%{box-shadow:0 0 0 0 rgba(22,163,74,0);}}
.float-cta-main{font-family:'Josefin Sans',sans-serif;font-size:13px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;}
@media (max-width:380px){.float-cta{right:10px;bottom:10px;padding:9px 14px;}.float-cta-main{font-size:12px;}}
.halal-cert-badge { display:inline-flex; flex-direction:column; align-items:center; gap:6px; border:1.5px solid #c9a96e; border-radius:50%; width:88px; height:88px; justify-content:center; position:relative; background:radial-gradient(circle at center,rgba(201,169,110,0.08) 0%,transparent 70%); }
.halal-cert-badge::before { content:''; position:absolute; inset:4px; border-radius:50%; border:0.5px dashed rgba(201,169,110,0.4); }
.halal-cert-badge-wrap { display:flex; gap:20px; justify-content:center; flex-wrap:wrap; margin-top:2rem; }
.map-wrapper { position:relative; width:100%; padding-bottom:56.25%; height:0; overflow:hidden; border-radius:12px; border:1px solid rgba(201,169,110,0.2); }
.map-wrapper iframe { position:absolute; top:0; left:0; width:100%; height:100%; border:0; filter:grayscale(30%) contrast(1.05); }
.jp-text { font-family: 'Noto Serif JP', serif; font-weight: 300; letter-spacing: 0.15em; }
.year-badge { font-family:'Cormorant Garamond',serif; font-style:normal; font-size:3.5rem; color:rgba(201,169,110,0.2); line-height:1; }
.section-label { font-size:10px; letter-spacing:0.3em; color:rgba(201,169,110,0.6); text-transform:uppercase; }
.slide { transition: opacity 1.2s ease-in-out; }
.course-scroll { display:flex; gap:16px; overflow-x:auto; padding:8px 0 16px; -ms-overflow-style:none; scrollbar-width:none; }
.course-scroll::-webkit-scrollbar { display:none; }
.course-card { width:auto; border-radius:16px; overflow:hidden; }
@media (min-width:768px) {
  .course-scroll { display:grid; grid-template-columns:repeat(3,1fr); overflow-x:visible; }
}
.course-detail-panel { max-height:0; overflow:hidden; transition:max-height 0.4s ease; }
.course-detail-panel.open { max-height:600px; }
.course-hl{color:var(--cat);font-weight:500;}
.course-hl-tag{display:inline-block;font-family:'Josefin Sans',sans-serif;font-size:7px;letter-spacing:0.1em;text-transform:uppercase;color:var(--cat);border:1px solid var(--cat);border-radius:999px;padding:1px 5px;margin-left:3px;vertical-align:middle;opacity:0.85;}
/* course category accents */
.cat-sushi{--cat:#5dc9b0;--cat-soft:rgba(93,201,176,0.12);}
.cat-wagyu{--cat:#d36a5a;--cat-soft:rgba(211,106,90,0.12);}
.cat-mix{--cat:#c9a96e;--cat-soft:rgba(201,169,110,0.14);}
.course-card{position:relative;}
.course-card .cat-bar{height:4px;width:100%;background:var(--cat);}
.course-card .cat-badge{display:inline-flex;align-items:center;gap:5px;background:var(--cat-soft);color:var(--cat);border:1px solid var(--cat);border-radius:999px;padding:3px 9px;font-family:'Josefin Sans',sans-serif;font-size:9px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;margin-bottom:10px;}
.course-card .cat-badge svg{width:12px;height:12px;}
/* category legend chips */
.cat-legend{display:inline-flex;align-items:center;gap:6px;font-family:'Josefin Sans',sans-serif;font-size:10px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--cat);}
.cat-legend-dot{width:9px;height:9px;border-radius:50%;background:var(--cat);}
.chevron-icon { transition:transform 0.3s; }
.chevron-icon.open { transform:rotate(180deg); }
.booking-pulse { display:inline-block; width:8px; height:8px; border-radius:50%; background:#ef4444; margin-right:8px; animation: pulseRed 1.8s ease-in-out infinite; box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.7); }
@keyframes pulseRed {
  0% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.7); }
  70% { box-shadow: 0 0 0 8px rgba(239, 68, 68, 0); }
  100% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0); }
}
.review-scroll { display:flex; gap:16px; overflow-x:auto; padding:8px 0 16px; -ms-overflow-style:none; scrollbar-width:none; scroll-snap-type:x mandatory; }
.review-scroll::-webkit-scrollbar { display:none; }
.review-card { flex-shrink:0; width:300px; padding:24px; border-radius:16px; border:1px solid rgba(201,169,110,0.2); background:linear-gradient(135deg, rgba(201,169,110,0.06) 0%, rgba(201,169,110,0.02) 100%); scroll-snap-align:start; }
@media (min-width:768px) {
  .review-scroll { display:grid; grid-template-columns:repeat(2, 1fr); overflow-x:visible; }
  .review-card { width:auto; }
}
@media (min-width:1024px) {
  .review-scroll { grid-template-columns:repeat(3, 1fr); }
}

/* ===== Opening loader (concept loading, no image) ===== */
#opening-overlay{position:fixed;inset:0;z-index:9998;background:#070707;display:flex;flex-direction:column;align-items:center;justify-content:center;opacity:1;transition:opacity 0.9s ease;}
#opening-overlay.hide{opacity:0;pointer-events:none;}
.loader-mark{position:relative;width:74px;height:74px;display:flex;align-items:center;justify-content:center;margin-bottom:22px;}
.loader-ring{position:absolute;inset:0;border-radius:50%;border:1px solid rgba(201,169,110,0.25);}
.loader-ring::after{content:'';position:absolute;inset:-1px;border-radius:50%;border:1px solid transparent;border-top-color:#c9a96e;border-right-color:rgba(201,169,110,0.5);animation:loaderSpin 1.1s linear infinite;}
@keyframes loaderSpin{to{transform:rotate(360deg);}}
.loader-sun{width:30px;height:30px;border-radius:50%;background:radial-gradient(circle at 50% 50%,#d63a2f 0%,#c4302a 70%,#b02820 100%);box-shadow:0 0 22px rgba(214,58,47,0.55);animation:loaderPulse 1.8s ease-in-out infinite;}
@keyframes loaderPulse{0%,100%{transform:scale(0.9);opacity:0.85;}50%{transform:scale(1.05);opacity:1;}}
.loader-word{display:flex;flex-direction:column;align-items:center;gap:7px;text-align:center;animation:loaderReveal 2s ease forwards;}
.loader-word-1{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:22px;color:rgba(240,237,228,0.92);letter-spacing:0.04em;}
.loader-word-2{font-family:'Josefin Sans',sans-serif;font-weight:300;letter-spacing:0.36em;text-transform:uppercase;font-size:10px;color:rgba(201,169,110,0.85);padding-left:0.36em;}
@keyframes loaderReveal{0%{opacity:0;transform:translateY(6px);}100%{opacity:1;transform:translateY(0);}}
.loader-route{position:relative;margin-top:20px;width:180px;height:18px;}
.loader-route::before{content:'';position:absolute;top:50%;left:0;right:0;height:1px;background:repeating-linear-gradient(90deg,rgba(201,169,110,0.5) 0 5px,transparent 5px 11px);transform:translateY(-50%);}
.loader-plane{position:absolute;top:50%;left:0;width:16px;height:16px;color:#c9a96e;transform:translateY(-50%);animation:planeFly 2.0s ease-in-out infinite;filter:drop-shadow(0 0 6px rgba(201,169,110,0.6));}
.loader-plane svg{width:100%;height:100%;transform:rotate(90deg);}
@keyframes planeFly{0%{left:-6%;opacity:0;}15%{opacity:1;}85%{opacity:1;}100%{left:100%;opacity:0;}}

/* ===== Section divider — projection light beam ===== */
.pm-divider{position:relative;height:2px;width:100%;background:rgba(201,169,110,0.10);overflow:hidden;}
.pm-divider::after{content:'';position:absolute;top:0;left:0;height:100%;width:32%;background:linear-gradient(90deg,transparent,rgba(201,169,110,0.9),rgba(240,237,228,0.6),rgba(201,169,110,0.9),transparent);filter:blur(0.5px);animation:pmBeam 5.5s ease-in-out infinite;}
@keyframes pmBeam{0%{transform:translateX(-120%);}50%{transform:translateX(280%);}100%{transform:translateX(-120%);}}

/* ===== Hero (hero1: SP=portrait full, PC=16:11 center-crop) ===== */
#hero-stage{position:relative;width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:#070707;overflow:hidden;}
.hero-bg-video{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center center;filter:brightness(0.62) saturate(1.05) contrast(1.08);}
/* PC: show hero1 as a 16:11 window, cropping top/bottom, centered */
@media (min-width:768px){
  #hero{height:auto;aspect-ratio:16/11;max-height:88vh;}
  .hero-bg-video{object-fit:cover;object-position:center 42%;}
}
.hero-scrim-top{position:absolute;top:0;left:0;right:0;height:34%;background:linear-gradient(to bottom,rgba(7,7,7,0.78) 0%,rgba(7,7,7,0.28) 60%,transparent 100%);pointer-events:none;z-index:2;}
.hero-scrim-bottom{position:absolute;bottom:0;left:0;right:0;height:58%;background:linear-gradient(to top,rgba(7,7,7,0.92) 0%,rgba(7,7,7,0.48) 45%,transparent 100%);pointer-events:none;z-index:2;}
/* ===== Experience block: hero2 + hero3 side by side ===== */
.exp-vid{aspect-ratio:16/9;width:100%;overflow:hidden;border-radius:12px;background:#111;}
.exp-vid video{width:100%;height:100%;object-fit:cover;filter:brightness(0.70) saturate(1.04) contrast(1.06);}
/* ===== Hero title with hinomaru ===== */
.hero-title-wrap{padding:6px 10px;}
.hinomaru{position:absolute;top:50%;left:50%;width:150px;height:150px;border-radius:50%;background:radial-gradient(circle at 50% 50%, #d63a2f 0%, #c4302a 70%, #b02820 100%);transform:translate(-50%,-50%);z-index:0;opacity:0.92;box-shadow:0 0 50px rgba(214,58,47,0.5);}
.hero-title{z-index:1;text-shadow:0 2px 24px rgba(0,0,0,0.85),0 1px 4px rgba(0,0,0,0.9);}
.hero-sub{text-shadow:0 1px 12px rgba(0,0,0,0.95),0 0 30px rgba(0,0,0,0.8);}
@media (max-width:680px){.hinomaru{width:120px;height:120px;}}
</style>
</head>

<body class="bg-ginza-black text-ginza-ivory font-epilogue overflow-x-hidden">

<!-- OPENING LOADER -->
<div id="opening-overlay">
  <div class="loader-mark">
    <span class="loader-ring"></span>
    <span class="loader-sun"></span>
  </div>
  <div class="loader-word"><span class="loader-word-1">Welcome</span><span class="loader-word-2">Gastronomic Tour of Japan</span></div>
  <div class="loader-route">
    <span class="loader-plane" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M21 16v-2l-8-5V3.5a1.5 1.5 0 0 0-3 0V9l-8 5v2l8-2.5V19l-2 1.5V22l3.5-1 3.5 1v-1.5L11 19v-5.5z"/></svg>
    </span>
  </div>
</div>
<script>
(function(){
  var ov = document.getElementById('opening-overlay');
  if(!ov) return;
  function done(){ ov.classList.add('hide'); setTimeout(function(){ if(ov&&ov.parentNode) ov.parentNode.removeChild(ov); }, 1000); }
  // ページ表示後、最低2.2秒は見せてからフェード
  var shown = Date.now();
  window.addEventListener('load', function(){
    var wait = Math.max(0, 2200 - (Date.now()-shown));
    setTimeout(done, wait);
  });
  // 保険: load が来なくても3.5秒で必ず閉じる
  setTimeout(done, 3500);
})();
</script>

<!-- FLOATING AVAILABILITY BUTTON -->

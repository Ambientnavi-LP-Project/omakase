<script>
  var __callReserveTrigger = '';
  function openCallReserveModal(triggerLocation) {
    __callReserveTrigger = triggerLocation || '';
    var m = document.getElementById('callReserveModal');
    if (m) {
      m.classList.add('open');
      document.body.style.overflow = 'hidden';
    }
  }
  function closeCallReserveModal() {
    var m = document.getElementById('callReserveModal');
    if (m) {
      m.classList.remove('open');
      document.body.style.overflow = '';
    }
  }
  function trackCallReserve() {
    if (typeof gtag === 'function') {
      gtag('event', 'call_reserve_action', {
        'event_category': 'conversion',
        'event_label': __callReserveTrigger,
        'store_name': '{{ store.slug }}',
        'store_area': '{{ store.region }}',
        'brand': '{{ stores.brand.brand_slug }}',
        'channel': '{{ store.channel_id }}'
      });
    }
  }
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeCallReserveModal();
  });
</script>

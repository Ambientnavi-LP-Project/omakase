  <span class="float-cta-viewers"><span class="float-dot"></span><span id="viewer-count">5</span> people viewing now</span>
  <span class="float-cta-main">Check availability <span aria-hidden="true">→</span></span>
{% if store.is_form_reserve == 'true' or is_form_reserve == 'true' or store.tablecheck_url == 'TBD' %}
</button>
{% else %}
</a>

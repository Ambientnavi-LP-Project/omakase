<script>
(function(){
  var KEY='stay_modal_shown', DELAY=30000, shown=false;
  function alreadyShown(){try{return sessionStorage.getItem(KEY)==='1';}catch(e){return false;}}
  function markShown(){try{sessionStorage.setItem(KEY,'1');}catch(e){}}
  window.openStayModal=function(){
    if(shown||alreadyShown())return;
    var m=document.getElementById('stayModal'); if(!m)return;
    shown=true; markShown(); m.classList.add('open'); document.body.style.overflow='hidden';
    window.dataLayer.push({event:'stay_modal_open',event_label:'20s_timer'});
  };
  window.closeStayModal=function(how){
    var m=document.getElementById('stayModal'); if(!m)return;
    m.classList.remove('open'); document.body.style.overflow='';
    window.dataLayer.push({event:'stay_modal_close',event_label:how||'close'});
  };
  window.stayModalGoCourses=function(){
    closeStayModal('cta_courses');
    var t=document.getElementById('courses');
    if(t){requestAnimationFrame(function(){t.scrollIntoView({behavior:'smooth',block:'start'});});}
  };
  if(!alreadyShown()){setTimeout(window.openStayModal,DELAY);}
  document.addEventListener('keydown',function(e){if(e.key==='Escape'){var m=document.getElementById('stayModal');if(m&&m.classList.contains('open'))closeStayModal('esc');}});
})();
</script>


<script>
  const observer = new IntersectionObserver((e) => {
    e.forEach(el => { if (el.isIntersecting) el.target.classList.add('active'); });
  }, { threshold: 0.1 });
  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

  /* === カスタムイベント → GTM 経由で GA4 へ === */
  document.addEventListener('click', function(e){
    var el = e.target.closest('[data-ga-event]');
    if (!el) return;
    window.dataLayer.push({
      event: el.getAttribute('data-ga-event'),
      event_label: el.getAttribute('data-ga-location') || ''
    });
  }, true);
</script>

<script>
(function(){
  // 数時間おきに決定的に変わる booking 数(9〜19) と viewer 数(4〜8)
  function seeded(min,max,bucket){
    var h=(bucket*2654435761)%2147483647; var r=(h>>>0)/2147483647;
    return min+Math.floor(r*(max-min+1));
  }
  var now=Date.now();
  var bookingBucket=Math.floor(now/(3*3600*1000)); // 3時間ごと
  var viewerBucket=Math.floor(now/(7*60*1000));     // 約7分ごと
  var bookings=seeded(9,19,bookingBucket);
  var viewers=seeded(4,8,viewerBucket);
  document.querySelectorAll('.booking-count').forEach(function(el){el.textContent=bookings;});
  var v=document.getElementById('viewer-count'); if(v) v.textContent=viewers;
  // viewer数は滞在中ゆっくり揺らす
  setInterval(function(){
    if(!v) return;
    var cur=parseInt(v.textContent,10)||5;
    var d=Math.random()<0.5?-1:1;
    cur=Math.max(4,Math.min(8,cur+d));
    v.textContent=cur;
  }, 9000);
})();
</script>


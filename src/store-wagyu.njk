{% if store.slug != 'shinjuku-sanchome' %}<div class="cc-course-price"><span class="cc-course-price-main">&yen;{{ comma(total) }}</span><span class="cc-course-price-tax">(&yen;{{ comma(incl) }} incl. tax)</span></div>{% endif %}
{% if c.diff %}<p class="cc-course-diff">{{ c.diff | safe }}</p>{% endif %}
<button type="button" class="cc-course-toggle" onclick="toggleCourseDetail('{{ c.id }}')" aria-expanded="false" data-ga-event="course_detail_view" data-ga-location="course_modal_{{ c.id }}">
<span>See details</span>
<svg class="cc-chevron" id="cc-chevron-{{ c.id }}" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5"/></svg>
</button>
<div class="cc-course-rows" id="cc-detail-{{ c.id }}">
<div class="cc-course-rows-inner">
{% for r in c.rows %}
<div class="cc-course-row"><span class="cc-course-row-k">{{ r[0] }}</span><span class="cc-course-row-v">{{ r[1] | safe }}</span></div>
{% endfor %}
</div>
</div>
{% if store.slug != 'shinjuku-sanchome' %}
{% if store.is_form_reserve == 'true' or is_form_reserve == 'true' %}
<button onclick="closeCourseCat('{{ cat.key }}'); openReserveModal('course_modal', '{{ c.id }}')" class="cc-course-reserve" data-ga-event="reserve_click" data-ga-location="course_modal_{{ c.id }}">
<svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" stroke="#090909" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
Reserve this course
</button>
{% elif store.tablecheck_url == 'TBD' %}
<button onclick="closeCourseCat('{{ cat.key }}'); openCallReserveModal('course_modal_{{ c.id }}')" class="cc-course-reserve" data-ga-event="reserve_click" data-ga-location="course_modal_{{ c.id }}">
<svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" stroke="#090909" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
Reserve this course
</button>
{% else %}
<a href="{{ tablecheck_with_utm }}" target="_blank" rel="noopener" class="cc-course-reserve" data-ga-event="reserve_click" data-ga-location="course_modal_{{ c.id }}">
<svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" stroke="#090909" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
Reserve this course
</a>
{% endif %}
{% endif %}
</div>
</div>
{% endif %}{% endfor %}
</div>
</div>
</div>
{% endfor %}


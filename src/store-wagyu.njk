.hero-course{position:relative;max-width:760px;margin:0 auto;display:flex;flex-direction:column;background:linear-gradient(180deg,rgba(201,169,110,0.06),rgba(255,255,255,0));border:1px solid rgba(201,169,110,0.5);border-radius:18px;overflow:hidden;box-shadow:0 0 34px rgba(201,169,110,0.16);}
@media (min-width:768px){.hero-course{flex-direction:row;}}
.hero-course-ribbon{position:absolute;top:14px;left:14px;z-index:3;background:#c9a96e;color:#090909;font-family:'Josefin Sans',sans-serif;font-size:10px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;padding:4px 12px;border-radius:999px;box-shadow:0 3px 12px rgba(0,0,0,0.4);}
.hero-course-photo{position:relative;width:100%;height:180px;flex-shrink:0;background:rgba(201,169,110,0.08);overflow:hidden;}
@media (min-width:768px){.hero-course-photo{width:290px;height:auto;}}
.hero-course-photo img{width:100%;height:100%;object-fit:cover;display:block;}
.hero-course-photo-empty::after{content:'Photo';position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-family:'Josefin Sans',sans-serif;font-size:10px;letter-spacing:0.16em;text-transform:uppercase;color:rgba(240,237,228,0.3);}
.hero-course-body{flex:1;min-width:0;padding:20px 22px 22px;}
.hero-course-name{font-family:'Cormorant Garamond',serif;font-size:28px;font-weight:600;color:#f0ede4;line-height:1.1;margin:0 0 8px;}
.hero-course-hook{font-family:'Epilogue',sans-serif;font-weight:300;font-size:13px;line-height:1.55;color:rgba(240,237,228,0.72);margin:0 0 12px;}
.hero-course-fromrow{display:flex;align-items:baseline;gap:8px;flex-wrap:wrap;margin:0 0 14px;padding-bottom:14px;border-bottom:1px solid rgba(201,169,110,0.2);}
.hero-course-fromlabel{font-family:'Josefin Sans',sans-serif;font-size:11px;letter-spacing:0.12em;text-transform:uppercase;color:rgba(240,237,228,0.5);}
.hero-course-frommain{font-family:'Josefin Sans',sans-serif;font-size:28px;font-weight:700;color:#c9a96e;line-height:1;}
.hero-course-fromupto{font-family:'Epilogue',sans-serif;font-weight:300;font-size:11px;color:rgba(240,237,228,0.45);}
.hero-tier-list{display:flex;flex-direction:column;gap:10px;}
.hero-tier{display:flex;align-items:center;justify-content:space-between;gap:12px;width:100%;text-align:left;background:rgba(255,255,255,0.03);border:1px solid rgba(201,169,110,0.28);border-radius:14px;padding:15px 16px;min-height:62px;cursor:pointer;text-decoration:none;-webkit-tap-highlight-color:transparent;transition:transform .12s ease,box-shadow .2s ease,background .2s ease,border-color .2s ease;}
.hero-tier:active{transform:scale(0.985);}
.hero-tier-main{display:flex;flex-direction:column;gap:3px;min-width:0;}
.hero-tier-label{font-family:'Cormorant Garamond',serif;font-size:19px;font-weight:600;color:#f0ede4;line-height:1.1;}
.hero-tier-sub{font-family:'Josefin Sans',sans-serif;font-size:10px;letter-spacing:0.06em;color:rgba(240,237,228,0.55);}
.hero-tier-end{display:flex;flex-direction:column;align-items:flex-end;gap:3px;flex-shrink:0;}
.hero-tier-price{font-family:'Josefin Sans',sans-serif;font-size:18px;font-weight:700;color:#c9a96e;line-height:1;}
.hero-tier-cta{font-family:'Josefin Sans',sans-serif;font-size:10px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:rgba(240,237,228,0.5);white-space:nowrap;}
/* 主役(Web限定): ベタ塗りで一番目立たせる */
.hero-tier-primary{background:#c9a96e;border-color:#c9a96e;box-shadow:0 8px 22px rgba(201,169,110,0.38);}
.hero-tier-primary .hero-tier-label,.hero-tier-primary .hero-tier-price{color:#090909;}
.hero-tier-primary .hero-tier-sub{color:rgba(9,9,9,0.62);}
.hero-tier-primary .hero-tier-cta{color:rgba(9,9,9,0.8);}
.hero-tier-primary:hover{box-shadow:0 10px 28px rgba(201,169,110,0.5);}
/* プレミアム: グローで格上げ(色は増やさない) */
.hero-tier-premium{background:rgba(201,169,110,0.09);border-color:rgba(201,169,110,0.6);box-shadow:0 0 20px rgba(201,169,110,0.18);}
.hero-tier-premium .hero-tier-cta{color:#c9a96e;}
/* スタンダード: 控えめ(hover時のみ持ち上げ) */
.hero-tier-plain:hover{background:rgba(201,169,110,0.08);border-color:rgba(201,169,110,0.5);}

/* Lunch: 枠外(点線の控えめバナー) */
.lunch-out{display:flex;align-items:center;justify-content:space-between;gap:12px;max-width:760px;margin:18px auto 0;width:100%;background:rgba(208,162,76,0.08);border:1px solid rgba(208,162,76,0.5);border-radius:14px;padding:17px 20px;cursor:pointer;text-decoration:none;transition:background .2s,border-color .2s,transform .12s ease;}
.lunch-out:hover{background:rgba(208,162,76,0.13);border-color:rgba(208,162,76,0.7);}
.lunch-out:active{transform:scale(0.99);}
.lunch-out-l{font-family:'Epilogue',sans-serif;font-weight:300;font-size:14.5px;color:rgba(240,237,228,0.9);line-height:1.4;}
.lunch-out-l b{font-weight:600;color:#f0ede4;}
.lunch-out-sun{color:#d0a24c;font-size:16px;}
.lunch-out-r{display:flex;align-items:center;gap:8px;font-family:'Josefin Sans',sans-serif;font-size:17px;font-weight:700;color:#d0a24c;flex-shrink:0;white-space:nowrap;}
</style>
<script>
(function(){
  var openKey = null;
  window.openCourseCat = function(key){
    var m = document.getElementById('ccModal-' + key);
    if(!m) return;
    m.classList.add('open'); openKey = key; document.body.style.overflow = 'hidden';
    window.dataLayer.push({
      event: 'course_category_view',
      event_category: 'engagement',
      event_label: key,
      store_name: '{{ store.slug }}',
      store_area: '{{ store.region }}',
      brand: '{{ stores.brand.brand_slug }}',
      channel: '{{ store.channel_id }}'
    });
  };
  window.closeCourseCat = function(key){
    var m = document.getElementById('ccModal-' + (key || openKey));
    if(!m) return;
    m.classList.remove('open'); document.body.style.overflow = ''; openKey = null;
  };
  window.toggleCourseDetail = function(id){
    var panel = document.getElementById('cc-detail-' + id);
    var chev = document.getElementById('cc-chevron-' + id);
    var btn = chev ? chev.closest('.cc-course-toggle') : null;
    if(!panel) return;
    var open = panel.classList.toggle('open');
    if(chev) chev.classList.toggle('open', open);
    if(btn){ btn.setAttribute('aria-expanded', open ? 'true' : 'false');
      var lbl = btn.querySelector('span'); if(lbl) lbl.textContent = open ? 'Hide details' : 'See details'; }
  };
  document.addEventListener('keydown', function(e){
    if(e.key === 'Escape' && openKey){ closeCourseCat(openKey); }
  });
})();
</script>
</body>
</html>
